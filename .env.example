# Personal Productivity Toolkit — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These values are read by the skills at runtime.
# The .env file is gitignored so your values stay local.

# Your Slack user ID (find it: click your profile pic in Slack → Profile → ⋮ → Copy member ID)
SLACK_USER_ID=

# Your Asana workspace and user GIDs (find them: Asana API or ask your admin)
ASANA_WORKSPACE_GID=
ASANA_USER_GID=

# Airtable base IDs (only needed for person-intelligence skill)
AIRTABLE_API_KEY=
PEOPLE_OPS_BASE_ID=
SLT_BASE_ID=
